# GTFS-RT (pas de clé nécessaire — flux public)
GTFS_RT_TRIP_UPDATES_URL=https://proxy.transport.data.gouv.fr/resource/sncf-gtfs-rt-trip-updates

# API Navitia (clé gratuite sur numerique.sncf.com/startup/api)
NAVITIA_API_KEY=your_key_here

# DuckDB
DUCKDB_PATH=./data/observatory.duckdb

# Scheduler
FETCH_INTERVAL_SECONDS=120